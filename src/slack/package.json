{
  "name": "@sigyn/slack",
  "version": "2.0.0",
  "description": "Send Sigyn alerts to Slack via webhook",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build",
    "test": "node --test ./test/**/*.spec.ts",
    "coverage": "c8 -r html npm test",
    "lint": "eslint src test"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenAlly/sigyn",
    "directory": "src/slack"
  },
  "bugs": {
    "url": "https://github.com/OpenAlly/sigyn/issues"
  },
  "homepage": "https://github.com/OpenAlly/sigyn/blob/main/src/slack/README.md",
  "files": [
    "dist"
  ],
  "keywords": [],
  "author": "GENTILHOMME Thomas <gentilhomme.thomas@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@openally/httpie": "^1.1.2",
    "@slack/types": "^2.14.0"
  }
}
